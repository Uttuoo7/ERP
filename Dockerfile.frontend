# Build stage
FROM node:18-alpine AS build

WORKDIR /app

COPY frontend/package*.json ./
RUN npm ci

COPY frontend/ ./
COPY .env ./

RUN npm run build

# Production stage
FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
# Copy standard nginx configuration if needed, or use default
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
