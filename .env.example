# ==============================================================================
# P2P ERP PRODUCTION ENV CONFIGURATION TEMPLATE
# ==============================================================================

# Server Context
PORT=8000
ENVIRONMENT=production # production, development, testing

# Security Hardening
# IMPORTANT: Generate strong random secrets for production
JWT_SECRET=generaterandomhexwithopensslrandhex32
SECRET_KEY=generaterandomhexwithopensslrandhex32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Allowed Origins (Comma-separated list)
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:5173,http://localhost:8000

# Database Resiliency Tuning
# In Docker production: postgresql://erp_user:erp_password@db:5432/p2p_erp
DATABASE_URL=postgresql://erp_user:erp_password@localhost:5432/p2p_erp
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Caching & Background Task Brokers
# In Docker production: redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=True

# Centralized Logging Controls
LOG_LEVEL=INFO
