# ============================================================
# Test Environment Variables
# Copy to .env before running tests locally:
#   copy .env.test .env.local.test
# ============================================================

# PostgreSQL Test Database (Docker on port 5433)
TEST_DATABASE_URL=postgresql://erp_test_user:erp_test_password@localhost:5433/p2p_erp_test

# JWT secret for test token generation
JWT_SECRET=test_jwt_secret_key_for_erp_testing_only
SECRET_KEY=test_jwt_secret_key_for_erp_testing_only

# Disable all background workers during tests
DISABLE_BACKGROUND_WORKERS=true

# CORS (allow all in test env)
CORS_ORIGINS=http://localhost:5173,http://localhost:8000
